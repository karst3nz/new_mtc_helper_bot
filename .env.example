# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_admin_id_here

# Schedule sending (1 to enable, 0 to disable)
SEND_RASP=1

# Backup chat ID (optional, defaults to ADMIN_ID)
BACKUP_CHAT_ID=your_backup_chat_id_here

# Telegram API credentials (optional, for custom bot API)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Custom Bot API URL (optional, leave empty for official API)
CUSTOM_API_URL=

# Debug mode (True/False)
DEBUG=False
